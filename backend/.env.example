# Mobile Gateway Backend Configuration

# Secret key for signing JWT tokens (should be a long random hex string in production)
SECRET_KEY=super_secret_signing_key_for_signlens_mobile_app_1234567890

# Database Connection URL
# For local SQLite development (default):
DATABASE_URL=sqlite:///./signlens_mobile.db
# For production MySQL / MariaDB (example):
# DATABASE_URL=mysql+pymysql://user:password@host:port/database

# ML Model Endpoints backend connection
MODEL_API_URL=http://127.0.0.1:8000
MODEL_API_WS_URL=ws://127.0.0.1:8000

# Private API Key generated from the Model Endpoints backend
MODEL_API_KEY=
